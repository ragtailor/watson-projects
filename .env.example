# cp .env.example .env 후 실제 값 입력

DATABASE_URL=postgresql://ragtaylor_user:CHANGE_ME@postgres:5432/ragtaylor_db
REDIS_URL=redis://redis:6379/1
OLLAMA_URL=http://host.docker.internal:11434
CORS_ORIGINS=https://api.ragtaylor.com,https://ragtaylor.com,https://www.ragtaylor.com

# 기존 로컬 스택(n8n/neo4j)용 — dreamscape와 무관
GEMINI_API_KEY=CHANGE_ME
NEO4J_PASSWORD=CHANGE_ME

# 로그인 게이트 (003) — 실제 값은 서버 .env에만 입력
AUTH_ID=CHANGE_ME
AUTH_PW=CHANGE_ME
SESSION_SECRET=CHANGE_ME

# star_craft — ConvNeXt Nano 이미지 분류 (zerg_observer, star-002)
INFERENCE_BACKEND=onnx
ZERG_OBSERVER_MODEL_NAME=convnext_nano
ZERG_OBSERVER_MAX_IMAGE_BYTES=10485760
ZERG_OBSERVER_CACHE_TTL_SECONDS=3600

# kingsman — 소셜 로그인 (구글/네이버/카카오/X)
# redirect_uri는 반드시 "{OAUTH_REDIRECT_BASE_URL}/api/kingsman/oauth/{provider}/callback"
# 형태로 각 프로바이더 콘솔에 등록된 값과 정확히 일치해야 한다.
OAUTH_REDIRECT_BASE_URL=http://127.0.0.1:8000
FRONTEND_REDIRECT_URL=http://localhost:3000
USER_SESSION_SECRET=CHANGE_ME
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME
NAVER_CLIENT_ID=CHANGE_ME
NAVER_CLIENT_SECRET=CHANGE_ME
KAKAO_CLIENT_ID=CHANGE_ME
KAKAO_CLIENT_SECRET=CHANGE_ME
X_CLIENT_ID=CHANGE_ME
X_CLIENT_SECRET=CHANGE_ME
