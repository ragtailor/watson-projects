# auth 컨테이너 전용 환경변수 (auth.ragtailor.com) — 토큰 발급.
# 실제 .env.auth 는 커밋 금지. 이 예시 파일에는 비밀값을 넣지 않는다.

# RS256 개인키. PEM 원문 또는 base64 인코딩(base64 -w0 jwt_private.pem) 모두 허용.
# 개인키는 오직 이 파일에만 존재해야 한다.
JWT_PRIVATE_KEY=

# RS256 공개키. auth 컨테이너는 들어오는 리프레시 토큰을 검증(/refresh, /logout)하므로
# 공개키도 필요하다. (공개키는 비밀이 아니다)
JWT_PUBLIC_KEY=

# 발급 토큰의 audience (백엔드의 SERVICE_AUD 와 일치해야 검증 통과)
SERVICE_AUD=ragtaylor-api

# 리프레시 토큰 저장/블랙리스트용 Redis (dreamscape totem)
REDIS_URL=redis://totem:6379/1

# OAuth 클라이언트 시크릿 (실제 프로바이더 연동 시)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
X_CLIENT_ID=
X_CLIENT_SECRET=

# 로그인 완료 후 리다이렉트할 프론트엔드
FRONTEND_REDIRECT_URL=http://localhost:3000
